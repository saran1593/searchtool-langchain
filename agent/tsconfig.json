{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "strict": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "lib": ["es2022","DOM"],
        "noEmit": true,
        "types": ["node"]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules"
    ]
}